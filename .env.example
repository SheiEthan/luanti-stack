# Environment configuration example
# Copy this file to .env and adjust as needed
# Note: .env is ignored by git

# Grafana Settings
# ⚠️ NEVER use admin/admin in production
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_INSTALL_PLUGINS=

# Prometheus Settings
PROMETHEUS_RETENTION=72h

# Luanti Server Settings
LUANTI_MAX_USERS=20
LUANTI_BIND_ADDRESS=0.0.0.0
LUANTI_PORT=30000

# Optional: For production
# DOMAIN=example.com
# TLS_ENABLED=false
